# Copy this file to .env and fill in the values before running:
#   cp .env.template .env

# ---------------------------------------------------------------------------
# Neo4j (required)
# ---------------------------------------------------------------------------
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me

# ---------------------------------------------------------------------------
# HuggingFace (required)
# ---------------------------------------------------------------------------
# Required by model-puller to download the LLM.
# Qwen/Qwen2.5-3B-Instruct is public, so a free account token is enough.
# Generate one at https://huggingface.co/settings/tokens (read-only scope).
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
